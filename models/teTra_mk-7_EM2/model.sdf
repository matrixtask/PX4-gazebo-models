    <!-- [MOD-4] Flaperon/spoiler DRAG term (custom). ADDS drag only; existing CL coefficients unchanged.
         dCdS = cd_plate * flap_area * sin(|delta|) per flaperon (servo_5,servo_6), summed; applied at CoM
         (symmetric up-deflection = pure drag, no roll). User-authorised drag-term addition. -->
    <plugin filename="FlaperonDrag" name="FlaperonDrag">
      <link_name>base_link</link_name>
      <air_density>1.2041</air_density>
      <cd_plate>1.0</cd_plate>
      <flap_area>0.81</flap_area>
      <baseline_rad>0.61</baseline_rad>
    </plugin>

