<?xml version="1.0" encoding="UTF-8"?>
<sdf version='1.10'>
  <model name='teTra_mk-7_EM2'>
    <pose>0 0 0.80 0 0 0</pose>
    <self_collide>false</self_collide>
    <static>false</static>

    <link name='base_link'>
      <enable_wind>true</enable_wind>
      <pose>0 0 0 0 0 0</pose>
      <inertial>
        <!-- CG fix: CoM moved to PX4's assumed CG (0,0,-0.20) so gz physics match CA_ROTOR positions.
             Was (0.0785219319, 0, -0.4030751491). All 13 rotors' gz->FRD now equal CA_ROTOR (pusher 0.45 m
             above new CG == CA_ROTOR12_PZ=-0.45). Inertia tensor kept (parallel-axis shift ~1%). -->
        <pose>0 0 -0.20 0 0 0</pose>
        <mass>1293.575</mass>
        <inertia>
          <ixx>4393.261707</ixx>
          <ixy>0.000000</ixy>
          <ixz>-132.340036</ixz>
          <iyy>4262.626834</iyy>
          <iyz>-0.000000</iyz>
          <izz>8561.621614</izz>
        </inertia>
      </inertial>
      <collision name='fuselage_collision'>
        <!-- Shortened rear for pusher clearance: was 4.8 long centered at x=0 (rear -2.4 overlapped the
             pusher disc rotor_12 at x=-1.80, r=0.9). Now 3.8 long centered at x=+0.5 -> rear -1.4 (0.4 m
             clearance ahead of the pusher), nose +2.4 unchanged. Box has no mass -> CG unaffected. -->
        <pose>0.5 0 0 0 0 0</pose>
        <geometry>
          <box>
            <size>3.8 0.5 0.45</size>
          </box>
        </geometry>
        <surface>
          <contact>
            <ode>
              <kp>100000</kp>
              <kd>1.0</kd>
              <max_vel>0.1</max_vel>
              <min_depth>0.001</min_depth>
            </ode>
          </contact>
          <friction>
            <ode />
          </friction>
        </surface>
      </collision>
      <visual name='fuselage_visual'>
        <!-- Shortened rear for pusher clearance (see fuselage_collision). 3.8 long, centered x=+0.5. -->
        <pose>0.5 0 0 0 0 0</pose>
        <geometry>
          <box>
            <size>3.8 0.5 0.45</size>
          </box>
        </geometry>
        <material>
          <ambient>0.17 0.18 0.20 1</ambient>
          <diffuse>0.17 0.18 0.20 1</diffuse>
        </material>
      </visual>
      <!-- Simple fixed landing gear from CAD: 2.1 m wheelbase, 1.8 m main track, 15 in main wheels. -->
      <collision name='main_landing_gear_left_strut_collision'>
