      <visual name='rotor_12_blades_visual'><pose>0 0 0.020 0 0 0</pose><geometry><box><size>1.500 0.080 0.014</size></box></geometry><material><ambient>0.10 0.45 0.90 1</ambient><diffuse>0.10 0.45 0.90 1</diffuse></material></visual>
      <visual name='rotor_12_tip_marker_visual'><pose>0.700 0.100 0.030 0 0 0</pose><geometry><box><size>0.140 0.055 0.020</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual>
