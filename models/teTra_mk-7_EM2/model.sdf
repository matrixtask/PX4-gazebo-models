    </joint>

    <link name='rotor_12'>
      <!-- Pusher thrust-direction fix: MulticopterMotorModel applies thrust along the link local +Z.
           pitch -90deg put link +Z = model -X (BACKWARD, verified -1.49 m/s^2 body_vx). pitch +90deg makes
           link +Z = model +X (FORWARD). Joint axis stays +X (spin). Was: 0 -1.5707963268 0. -->
      <pose>-1.80 0 0.25 0 1.5707963268 0</pose>
      <inertial><mass>2.22</mass><inertia><ixx>0.19769</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.19769</iyy><iyz>0</iyz><izz>0.39538</izz></inertia></inertial>
